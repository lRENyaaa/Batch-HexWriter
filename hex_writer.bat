REM  Machine=0x014C(x86), NumberOfSections=2, SizeOfOptionalHeader=0xE0=224
<nul set /p ="%hex:~76,1%%hex:~1,1%">> "%fileName%"
REM  0x02 00 = NumberOfSections(2). Narrow byte + /u type produces "02 00" pair.
REM  This pattern absorbs the following odd NUL into a 2-byte even pair, letting
REM  the NUL cache use only even-sized blocks (no findstr-based odd-NUL generator).
<nul set /p ="%hex:~2,1%">tmp.bin
