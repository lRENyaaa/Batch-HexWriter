REM  SetFilePointer, trailing NUL absorbed via /u type
<nul set /p ="%hex:~83,1%%hex:~101,1%%hex:~116,1%%hex:~70,1%%hex:~105,1%%hex:~108,1%%hex:~101,1%%hex:~80,1%%hex:~111,1%%hex:~105,1%%hex:~110,1%%hex:~116,1%%hex:~101,1%">> "%fileName%"
