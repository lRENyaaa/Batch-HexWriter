REM
REM  Generates append_byte.exe byte-by-byte using only cmd.exe internal commands.
REM  No findstr, no certutil, no PowerShell — just cmd.exe and its built-in tools.
REM
REM  Three core techniques:
REM    1. %hex:~N,1% substring indexing  —  OEM-437 char map as a 256-byte LUT
REM    2. cmd /u /c "type X"             —  narrow-byte to wide-char re-interpreter
REM    3. U+1A00 (EOF in /u mode)        —  NUL seed generation with auto-truncation
REM
REM  Byte output strategies (chosen by byte value):
REM    %hex:~N,1%            —  any non-zero byte (except leading 0x20)
REM    narrow byte + /u type —  "XX 00" pair, absorbs odd NUL (XX < 0x80 only)
REM    U+XX00 + /u set/p     —  "00 XX" pair (XX >= 0x80, or 00-first order needed)
REM    prepare0x2000 function  —  "20 00" pair (set/p strips leading spaces)
REM
REM  Auto-generated by Java (exe generation portion). Source: append_byte_fasm.exe
REM  Manually adjusted to handle odd 0x00 bytes and leading 0x20 stripping.
REM
REM  0xCC fill convention: PE header fields that Windows ignores are filled with
REM  0xCC (x86 INT3) instead of 0x00. This reduces the number of NUL bytes the
REM  batch script must generate, since producing 0x00 in pure cmd is expensive.
REM  The exe is pre-processed by build.ps1 to maximize 0xCC coverage before
REM  the Java generator converts it into this batch script.
REM ==============================================================================
setlocal EnableDelayedExpansion
cd /d "%~dp0"
REM  Set UTF-8 early so echo output displays correctly and isn't cleared
REM  by subsequent code-page switches in helper functions.
chcp 65001 >nul

:start

echo [%time%] Preparing...

call :prepareHex
call :prepareNulCache
call :prepare0x2000

REM Original Source: append_byte_fasm.asm
set "fileName=ByteAppender.exe"
set "targetName=0-255.bin"
type nul > "%fileName%"
type nul > "%targetName%"

echo [%time%] Building %fileName%...

