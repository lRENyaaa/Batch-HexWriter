REM ============================== Helper Functions ==============================
REM Build the %hex% lookup table: each character at position N, when written
REM to a file with chcp 437, produces byte value N.
REM   Switch to UTF-8 to set the multi-byte string, then back to OEM-437.
REM Design constraint: cmd internal commands (set, echo, for) use C-style
REM   \0-terminated strings — variables cannot hold a bare 0x00 byte.
REM   NUL must be produced at the I/O boundary (stdout), not stored in a variable.
REM
REM   Two methods to produce 0x00 alongside a non-zero byte:
REM     [1] U+XX00 chars  →  UTF-16LE "00 XX"  →  cmd /u /c "<nul set /p =CHAR"
REM         Used when we need 00 XX order, or when XX >= 0x80.
REM     [2] narrow byte   →  /u type reinterpret  →  "XX 00"
REM         Used when XX < 0x80 (safe code-page round-trip). Absorbs odd NUL.
REM
REM   Method [2] is preferred wherever possible — it avoids introducing new
REM   Unicode characters and uses the same hex lookup table as normal bytes.
:prepareHex
chcp 65001 >nul
REM  256-byte OEM-437 mapping indexed by %hex:~N,1%
set "hex=-☺☻♥♦♣♠•◘○◙♂♀♪♫☼►◄↕‼¶§▬↨↑↓→←∟↔▲▼ ！“#$％%&'()*+,-./0123456789：；＜＝＞？@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\]＾_`abcdefghijklmnopqrstuvwxyz{｜}~⌂ÇüéâäàåçêëèïîìÄÅÉæÆôöòûùÿÖÜ¢£¥₧ƒáíóúñÑªº¿⌐¬½¼¡«»░▒▓│┤╡╢╖╕╣║╗╝╜╛┐└┴┬├─┼╞╟╚╔╩╦╠═╬╧╨╤╥╙╘╒╓╫╪┘┌█▄▌▐▀αßΓπΣσµτΦΘΩδ∞φε∩≡±≥≤⌠⌡÷≈°∙·√ⁿ²■ "
REM  U+XX00 chars → UTF-16LE "00 XX" in /u mode.
REM  Only needed when XX >= 0x80 (UTF-8 multi-byte, unsafe for /u type round-trip)
REM  or when "00 XX" order is required instead of "XX 00".
REM U+0E00 → 00 0E (DOS stub signature prefix)
set "hex000e=฀"
REM U+0F00 → 00 0F (SizeOfOptionalHeader LSB)
set "hex000f=ༀ"
REM U+2E00 → 00 2E ('.' = .text section name prefix)
set "hex002e=⸀"
REM U+1A00 → 00 1A (EOF seed: /u type strips it, leaves 00 00)
set "hex001a=ᨀ"
REM U+0400 → 00 04 (idata field)
set "hex0004=Ѐ"
REM U+1A20 → 20 1A (seed for 20 00 pair via /u type)
set "hex201a=ᨠ"
REM U+AA00 → 00 AA (fill byte)
set "hex00aa=ꨀ"
chcp 437 >nul
goto :eof

REM Build all NUL-byte cache files from a single 00 1A seed, no external tools needed.
REM   Step 1: U+1A00 → /u set/p → 00 1A (raw)
REM   Step 2: 00 1A → /u type → 00 00  (U+001A=EOF in /u text mode, stripped)
REM   Step 3: copy /b doubling + composition for all required even sizes
:prepareNulCache
mkdir nul_cache 2>nul
pushd nul_cache

REM Generate seed NUL pair: 00 1A → /u type → 00 00
cmd /u /c "<nul set /p =%hex001a%">0x001a.bin
cmd /u /c "type 0x001a.bin">nul_2.bin

REM Clean temp file
del /f /q 0x001a.bin >nul 2>&1

REM Power-of-2 doubling chain
copy /b nul_2.bin + nul_2.bin nul_4.bin >nul
copy /b nul_4.bin + nul_4.bin nul_8.bin >nul
copy /b nul_8.bin + nul_8.bin nul_16.bin >nul
copy /b nul_16.bin + nul_16.bin nul_32.bin >nul
copy /b nul_32.bin + nul_32.bin nul_64.bin >nul
copy /b nul_64.bin + nul_64.bin nul_128.bin >nul
copy /b nul_128.bin + nul_128.bin nul_256.bin >nul
REM Composite sizes — all EVEN. Odd-sized NUL blocks (nul_1, nul_3,
REM nul_115, nul_343 from the original writer.bat with findstr) were
REM eliminated by absorbing one adjacent byte into each NUL region.
REM The adjacent byte + 0x00 is written as a single "XX 00" pair via
REM /u type in the main body, avoiding the need for an odd-size cache.
REM See the "XX 00 via /u type" pattern throughout the writer body.
copy /b nul_2.bin + nul_8.bin nul_10.bin >nul
copy /b nul_4.bin + nul_8.bin nul_12.bin >nul
copy /b nul_2.bin + nul_2.bin + nul_2.bin nul_6.bin >nul
copy /b nul_16.bin + nul_4.bin + nul_2.bin nul_22.bin >nul
copy /b nul_32.bin + nul_16.bin + nul_8.bin nul_56.bin >nul
copy /b nul_64.bin + nul_32.bin + nul_16.bin + nul_2.bin nul_114.bin >nul
copy /b nul_256.bin + nul_32.bin + nul_8.bin + nul_4.bin nul_300.bin >nul
copy /b nul_256.bin + nul_64.bin + nul_16.bin + nul_4.bin + nul_2.bin  nul_342.bin >nul
popd
goto :eof

REM prepare0x2000 — Generate "20 00" byte pair (0x20 + NUL).
REM
REM   In this script, 0x00 bytes are produced via even-sized nul_cache files.
REM   After a nul_cache append, the file ends at a NUL byte. If the very next
REM   byte to write is 0x20, <nul set /p will treat it as a leading space and
REM   strip it — a boundary case where 0x20 immediately follows a 0x00 region.
REM
REM   The narrow-byte + /u type trick also fails for 0x20.
REM
REM   The solution relies on a specific property of this PE file: every
REM   boundary 0x20 appears as a single byte sandwiched between two 0x00
REM   regions — the pattern "00 20 00". Instead of producing the 0x20 alone
REM   (which set/p would strip), we produce "20 00" as a pair via 0x2000.bin,
REM   leaving the surrounding 0x00 bytes to the normal nul_cache.
REM
REM   Mechanism: same U+1A00 seed trick as NUL generation.
REM     U+1A20 → /u set/p → 20 1A  →  /u type → 20 00
REM     U+001A (= 1A 00 in UTF-16LE) is the EOF character in /u text mode.
REM     /u type hits it and stops, truncating output to just "20 00".
REM
REM   Called once at startup; the resulting 0x2000.bin (contains "20 00") is
REM   used inline wherever a PE field begins with 0x20 (e.g., .text
REM   Characteristics, .idata VirtualAddress).
:prepare0x2000

REM Generate seed 0x20 0x00: 20 1A → /u type → 20 00
cmd /u /c "<nul set /p =%hex201a%">0x201a.bin
cmd /u /c "type 0x201a.bin">0x2000.bin

REM Clean temp file
del /f /q 0x201a.bin >nul 2>&1
goto :eof