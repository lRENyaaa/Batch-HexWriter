<nul set /p ="%hex:~67,1%%hex:~114,1%%hex:~101,1%%hex:~97,1%%hex:~116,1%%hex:~101,1%%hex:~70,1%%hex:~105,1%%hex:~108,1%%hex:~101,1%">> "%fileName%"
<nul set /p ="%hex:~65,1%">tmp.bin
